# PostgreSQL Connection Configuration
# You can use a single Connection String:
DATABASE_URL=postgresql://postgres:password@localhost:5432/recitation

# Or specify individual parameters:
# PGHOST=localhost
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=recitation
# PGPORT=5432

# Express Server Port
PORT=5001

# AI Model Configuration for grading
AI_API_KEY=your_openai_or_deepseek_api_key
AI_API_URL=https://api.deepseek.com/v1
AI_API_MODEL=deepseek-chat
AI_API_MODEL_GRADER=deepseek-chat
AI_TEMPERATURE=0.2
ENABLE_AI_GRADING=true
